SERVER_PORT=8080
SERVER_HOST=0.0.0.0

WEBHOOK_KEY_GRAFANA_TEST=test-key-grafana-local
WEBHOOK_KEY_SCRIPT_DEV=test-key-script-dev

ICINGA2_HOST=https://icinga2:5665
ICINGA2_USER=apiuser
ICINGA2_PASS=apipassword
ICINGA2_HOST_NAME=test-host
ICINGA2_HOST_AUTO_CREATE=true
ICINGA2_HOST_DISPLAY=Test Host (webhook-bridge)
ICINGA2_HOST_ADDRESS=127.0.0.1
ICINGA2_TLS_SKIP_VERIFY=true

HISTORY_FILE=/var/log/webhook-bridge/history.jsonl
HISTORY_MAX_ENTRIES=1000
CACHE_TTL_MINUTES=30
LOG_LEVEL=debug
LOG_FORMAT=text

ADMIN_USER=admin
ADMIN_PASS=admin123

RATELIMIT_MUTATE_MAX=5
RATELIMIT_STATUS_MAX=20
RATELIMIT_MAX_QUEUE=100
