# ── SERVER ──────────────────────────────────────────────────────
# Port and host the webhook bridge listens on
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# ── WEBHOOK API KEYS ───────────────────────────────────────────
# Format: WEBHOOK_KEY_<SOURCE_NAME>=<secret_key>
# The SOURCE_NAME becomes the source identifier in history logs
# (lowercased, underscores replaced with hyphens)
WEBHOOK_KEY_GRAFANA_PROD=your-secret-key-for-production
WEBHOOK_KEY_GRAFANA_DEV=your-secret-key-for-development
# WEBHOOK_KEY_GRAFANA_STAGING=your-secret-key-for-staging

# ── ICINGA2 REST API ───────────────────────────────────────────
# Used for all Icinga2 operations: passive check results,
# service creation/deletion (test mode)
ICINGA2_HOST=https://icinga2.example.com:5665
ICINGA2_USER=apiuser
ICINGA2_PASS=your-icinga2-api-password
ICINGA2_HOST_NAME=monitored-host
# Skip TLS certificate verification (only for development!)
ICINGA2_TLS_SKIP_VERIFY=false

# ── HISTORY ────────────────────────────────────────────────────
# JSONL file for recording all webhook events
HISTORY_FILE=/var/log/webhook-bridge/history.jsonl
# Maximum entries before rotation (oldest entries are trimmed)
HISTORY_MAX_ENTRIES=10000

# ── CACHE ──────────────────────────────────────────────────────
# TTL for the in-memory service cache (minutes)
CACHE_TTL_MINUTES=60

# ── LOGGING ────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info
# Log format: json | text
LOG_FORMAT=json
